/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2711";

    fragment@0 {
        target = <&i2c1>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells    = <0>;
            status         = "okay";
            clock-frequency = <100000>; /* 100 kHz standard mode */

            bme280@76 {
                compatible    = "bosch,bme280";
                reg           = <0x76>;
                status        = "okay";
            };
        };
    };

    fragment@1 {
        target = <&spi0>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells    = <0>;
            status         = "okay";

            mcp3008@0 {
                compatible        = "microchip,mcp3008";
                reg               = <0>;
                spi-max-frequency = <1350000>;
                vref-supply       = <&vdd_3v3_reg>;
                status            = "okay";
            };
        };
    };
};
